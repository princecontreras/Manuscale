# Gemini API Key (Server-side only - NOT exposed to browser)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Configuration (client-side, safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_FIRESTORE_DB_ID=your_firestore_db_id

# Firebase Admin SDK — used to verify user ID tokens in API routes (server-side only).
# Option A (recommended): Paste the full service account JSON as a single-line string.
#   Generate at: Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_ADMIN_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Option B (fallback — token verification only, no Firestore Admin access):
#   Omit FIREBASE_ADMIN_SERVICE_ACCOUNT and only set the project ID.
#   firebase-admin will use the public JWKS endpoint for ID token verification.
FIREBASE_ADMIN_PROJECT_ID=your_project_id

# Google Analytics (optional — client-side, safe to expose)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Stripe (Billing & Subscriptions)
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Product Price IDs
# Get PRICE IDs (not product IDs) from: https://dashboard.stripe.com/prices
# Format: price_1234567890abcdef (starts with "price_")
# Create two products:
#   - Monthly: $19 AUD/month
#   - Yearly: $169 AUD/year (26% discount)
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_1234567890abcdefghij
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=price_9876543210zyxwvutsrq

# App URL (used in Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
