rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Users can read and write their own profile document
    // This includes email, displayName, photoURL, but NOT subscription/billing data
    match /users/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      
      // Restrict write to safe fields only - block subscription/billing fields
      allow write: if isAuthenticated() && isOwner(userId) && 
        !request.resource.data.keys().hasAny(['stripeCustomerId', 'subscriptionId', 'subscriptionStatus', 'currentPeriodEnd', 'plan', 'updatedAt', 'createdAt']);
      
      // Note: Server-side operations (Stripe webhooks, admin operations, etc.) use the Admin SDK
      // and bypass these rules, so subscription updates work correctly.
      // Safe fields users can update: displayName, photoURL, email preferences, etc.
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
